def Factorial(numero):
        if numero==0 or numero==1:
            return 1;
        else: 
            return numero*Factorial(numero-1)
def Aritmetica(numero,numero1):
        if numero1==0:
            return 1
        elif(numero1%2!=0):
           X=numero**numero1
           S=X/Factorial(numero1)
           return S+Aritmetica(numero,numero1-1)
def Suma(numero):
    if numero == 0:
        return 0

    if numero % 2 == 0:
        return -numero + Suma(numero - 1)
    else:
        return numero + Suma(numero - 1)
